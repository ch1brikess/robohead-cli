#!/usr/bin/env python3

import argparse
import subprocess
import sys
import os
import json
import re
import shutil
from pathlib import Path
from datetime import datetime

HOME = Path.home()
WS_ROOT = HOME / "robohead_ws"
CONTROLLER_ROOT = WS_ROOT / "src" / "robohead" / "robohead_controller"
CONFIG_DIR = CONTROLLER_ROOT / "config"
VOICE_CONFIG_DIR = CONFIG_DIR / "voice_recognizer_pocketsphinx"
ACTIONS_DIR = CONTROLLER_ROOT / "scripts" / "robohead_controller_actions"

GRAM_FILE = VOICE_CONFIG_DIR / "gram.txt"
DICT_FILE = VOICE_CONFIG_DIR / "dictionary.txt"
DICT_OUTPUT_FILE = VOICE_CONFIG_DIR / "dictionary.dict"
YAML_CONFIG = CONFIG_DIR / "robohead_controller.yaml"
DICT2TRANSCRIPT_PATH = WS_ROOT / "src" / "ru4sphinx" / "text2dict" / "dict2transcript.pl"

IMAGE_DIR = HOME / "OS_image"
PISHRINK_PATH = "/usr/local/bin/pishrink.sh"

def check_ros():
    if not WS_ROOT.exists():
        print(f"ROS workspace не найден: {WS_ROOT}")
        sys.exit(1)

def run_cmd(cmd):
    try:
        subprocess.run(cmd, shell=True, check=True, cwd=HOME, executable='/bin/bash')
    except Exception as e:
        print(f"Ошибка: {e}")
        sys.exit(1)

def run_cmd_capture(cmd):
    try:
        result = subprocess.run(cmd, shell=True, capture_output=True, text=True, cwd=HOME, executable='/bin/bash')
        return result.stdout
    except Exception as e:
        print(f"Ошибка: {e}")
        return None

def backup(filepath):
    backup_path = str(filepath) + ".bak"
    shutil.copy2(filepath, backup_path)
    print(f"Бэкап: {backup_path}")

def check_pishrink():
    if not os.path.exists(PISHRINK_PATH):
        print("PiShrink не найден. Установка...")
        run_cmd(f"wget https://raw.githubusercontent.com/Drewsif/PiShrink/master/pishrink.sh -O {PISHRINK_PATH}")
        run_cmd(f"chmod +x {PISHRINK_PATH}")
        print("PiShrink установлен")

def core_get_img(args):
    # Определение устройства
    device = args.device if args.device else None
    
    if not device:
        print("Автоматическое определение SD-карты...")
        output = run_cmd_capture("lsblk -d -o NAME,SIZE,TYPE | grep disk")
        print("Доступные диски:")
        print(output)
        device = input("Введите имя диска (например, mmcblk0 или sdc): ").strip()
        if not device:
            device = "mmcblk0"
        if not device.startswith("/dev/"):
            device = f"/dev/{device}"
    
    print(f"Используемое устройство: {device}")
    
    # Проверка существования устройства
    if not os.path.exists(device):
        print(f"Ошибка: Устройство {device} не найдено")
        print("Проверьте подключение SD-карты и выполните: lsblk")
        return
    
    # Проверка: не примонтирована ли карта
    mount_output = run_cmd_capture(f"mount | grep {device}")
    if mount_output and mount_output.strip():
        print(f"Внимание: Устройство {device} примонтировано!")
        print("Размонтируйте перед созданием образа:")
        print(f"  sudo umount {device}*")
        if input("Размонтировать автоматически? (y/n): ").lower() == 'y':
            run_cmd(f"sudo umount {device}*")
            print("Размонтировано")
        else:
            print("Отменено пользователем")
            return
    
    # Определение выходного пути
    if args.output:
        output_path = Path(args.output)
        # Если не указано расширение .img, добавить
        if output_path.suffix != '.img' and not args.pack2:
            output_path = output_path.with_suffix(output_path.suffix + '.img')
        elif args.pack2 and output_path.suffix != '.gz':
            if output_path.suffix == '.img':
                output_path = Path(str(output_path) + '.gz')
            else:
                output_path = Path(str(output_path) + '.img.gz')
    else:
        # Путь по умолчанию: ~/OS_image/
        IMAGE_DIR.mkdir(parents=True, exist_ok=True)
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        output_path = IMAGE_DIR / f"robohead_image_{timestamp}.img"
    
    # Создание родительской директории
    output_path.parent.mkdir(parents=True, exist_ok=True)
    print(f"Директория: {output_path.parent}")
    print(f"Выходной файл: {output_path}")
    
    # Проверка свободного места на целевом разделе
    print("\nПроверка свободного места...")
    try:
        free_space = run_cmd_capture(f"df -BG '{output_path.parent}' | tail -1 | awk '{{print $4}}' | sed 's/G//'")
        free_gb = int(free_space.strip())
        print(f"Свободно на разделе: {free_gb} ГБ")
    except:
        free_gb = 0
        print("Не удалось определить свободное место")
    
    # Шаг 1: Создание сырого образа (dd)
    print("\n[1/3] Создание сырого образа...")
    print("Это может занять несколько минут...")
    dd_cmd = f"sudo dd bs=4M status=progress if={device} of='{output_path}'"
    
    try:
        result = subprocess.run(dd_cmd, shell=True, cwd=HOME, executable='/bin/bash')
        if result.returncode != 0:
            print(f"\nОшибка dd: код возврата {result.returncode}")
            print("\nВозможные причины:")
            print("  1. SD-карта примонтирована — выполните: sudo umount /dev/mmcblk0*")
            print("  2. Недостаточно места — проверьте: df -h")
            print("  3. Неверный путь к устройству — проверьте: lsblk")
            print("  4. Карта повреждена или извлечена")
            
            # Очистить частичный файл
            if output_path.exists():
                os.remove(output_path)
                print(f"Удалён частичный файл: {output_path}")
            return
        print(f"Образ создан: {output_path}")
        print(f"Размер: {os.path.getsize(output_path) / (1024**3):.2f} ГБ")
    except Exception as e:
        print(f"Ошибка при создании образа: {e}")
        return
    
    # Шаг 2: Сжатие через PiShrink (если --pack или --2pack)
    if args.pack or args.pack2:
        print("\n[2/3] Сжатие образа через PiShrink...")
        check_pishrink()
        try:
            run_cmd(f"sudo {PISHRINK_PATH} '{output_path}'")
            print(f"Образ сжат: {output_path}")
            print(f"Новый размер: {os.path.getsize(output_path) / (1024**3):.2f} ГБ")
        except Exception as e:
            print(f"Ошибка при сжатии: {e}")
            return
    
    # Шаг 3: Архивация в gzip (если --2pack)
    if args.pack2:
        print("\n[3/3] Архивация в gzip...")
        try:
            run_cmd(f"gzip '{output_path}'")
            gzip_path = Path(f"{output_path}.gz")
            print(f"Архив создан: {gzip_path}")
            print(f"Итоговый размер: {os.path.getsize(gzip_path) / (1024**3):.2f} ГБ")
        except Exception as e:
            print(f"Ошибка при архивации: {e}")
            return
    
    print("\nГотово!")
    print(f"Файл сохранён в: {output_path.parent}")

def core_restart(args):
    check_ros()
    if args.debug:
        cmd = "sudo systemctl stop robohead.service && roslaunch robohead_controller robohead_controller_py.launch"
        print(f"Режим отладки: {cmd}")
        if input("Выполнить? (y/n): ").lower() == 'y':
            run_cmd(cmd)
    else:
        print("Перезапуск robohead_controller...")
        run_cmd("sudo systemctl restart robohead.service")

def core_start(args):
    check_ros()
    print("Запуск robohead_controller...")
    run_cmd("sudo systemctl start robohead.service")

def core_stop(args):
    check_ros()
    print("Остановка robohead_controller...")
    run_cmd("sudo systemctl stop robohead.service")

def core_shutdown(args):
    sync = "" if args.no_sync else "-h"
    cmd = f"sudo shutdown {sync} now"
    print(f"ВЫКЛЮЧЕНИЕ: {cmd}")
    if input("Подтвердить? (y/n): ").lower() == 'y':
        run_cmd(cmd)

def core_reboot(args):
    cmd = "sudo reboot"
    print(f"ПЕРЕЗАГРУЗКА: {cmd}")
    if input("Подтвердить? (y/n): ").lower() == 'y':
        run_cmd(cmd)

def set_volume(args):
    volume = None
    
    if args.default:
        volume = 50
    elif args.VOLUME is not None:
        try:
            volume = int(args.VOLUME)
            if volume < 0 or volume > 100:
                print("Громкость должна быть от 0 до 100")
                return
        except:
            print(f"Неверное значение громкости: {args.VOLUME}")
            return
    else:
        print("Укажите громкость или используйте --default")
        return
    
    if args.now:
        print(f"Громкость: {volume}% (текущий сеанс)")
        run_cmd(f"amixer sset Master {volume}%")
    
    if args.standart:
        if YAML_CONFIG.exists():
            backup(YAML_CONFIG)
            with open(YAML_CONFIG, 'r') as f:
                content = f.read()
            if "speakers_volume:" in content:
                content = re.sub(r'speakers_volume:\s*\d+', f'speakers_volume: {volume}', content)
            else:
                content = content.replace('speakers:', f'speakers:\n  volume: {volume}\n  #')
            with open(YAML_CONFIG, 'w') as f:
                f.write(content)
            print(f"Громкость {volume}% сохранена для автозапуска")

def set_audio(args):
    if not args.from_file or not args.to_module:
        print("Требуются: --from-file и --to-module")
        return
    
    parts = args.to_module.split('.')
    if len(parts) < 3 or parts[0] != 'robohead_controller_actions':
        print(f"Неверный формат модуля: {args.to_module}")
        return
    
    name = parts[1]
    action_dir = ACTIONS_DIR / name
    
    if not action_dir.exists():
        print(f"Модуль не найден: {action_dir}")
        return
    
    dest = action_dir / Path(args.from_file).name
    shutil.copy2(args.from_file, dest)
    print(f"Аудио скопировано: {args.from_file} -> {dest}")

def rebuild_dict(args):
    check_ros()
    if not DICT_FILE.exists():
        print(f"Файл словаря не найден: {DICT_FILE}")
        return
    
    if not DICT2TRANSCRIPT_PATH.exists():
        print(f"dict2transcript.pl не найден: {DICT2TRANSCRIPT_PATH}")
        return
    
    print("Пересборка словаря...")
    cmd = f"{DICT2TRANSCRIPT_PATH} {DICT_FILE} {DICT_OUTPUT_FILE}"
    
    try:
        run_cmd(cmd)
        print("Словарь пересобран успешно!")
        print("Перезапустите robohead_controller для применения:")
        print("  robohead core restart")
    except Exception as e:
        print(f"Ошибка: {e}")

def add_word(args):
    check_ros()
    word = args.WORD.strip().lower()
    vol = args.act_volume if args.act_volume else 40
    
    if DICT_FILE.exists():
        with open(DICT_FILE, 'r') as f:
            words = [line.strip().lower() for line in f if line.strip()]
        if word not in words:
            with open(DICT_FILE, 'a') as f:
                f.write(f"{word}\n")
            print(f"Слово '{word}' добавлено в словарь")
    
    if GRAM_FILE.exists():
        backup(GRAM_FILE)
        with open(GRAM_FILE, 'r') as f:
            content = f.read()
        if f'= {word}' not in content:
            if '<command> =' in content:
                content = content.replace('<command> =', f'<command> = <command_{word}> |')
                content += f"\n<command_{word}> = {word} ;\n"
            with open(GRAM_FILE, 'w') as f:
                f.write(content)
            print(f"Команда '{word}' добавлена в грамматику")
    
    print(f"Порог активации: {vol} дБ")
    print("Выполните: robohead config words --rebuild")

def write_dict(args):
    src = Path(args.PATH)
    if not src.exists():
        print(f"Файл не найден: {src}")
        return
    if DICT_FILE.exists():
        backup(DICT_FILE)
    shutil.copy2(src, DICT_FILE)
    print(f"Словарь заменён: {src} -> {DICT_FILE}")
    print("Выполните: robohead config words --rebuild")

def list_actions(args):
    check_ros()
    if not ACTIONS_DIR.exists():
        print(f"Директория действий не найдена: {ACTIONS_DIR}")
        return
    
    actions = [d.name for d in ACTIONS_DIR.iterdir() if d.is_dir() and (d / 'action.py').exists()]
    
    if not actions:
        print("Список действий пуст")
        return
    
    print(f"Доступные действия ({len(actions)}):")
    for name in sorted(actions):
        path = ACTIONS_DIR / name / 'action.py'
        date = datetime.fromtimestamp(os.path.getmtime(path)).strftime('%Y-%m-%d')
        print(f"   - {name:20} [обновлено: {date}]")

def create_action(args):
    check_ros()
    name = args.NAME.strip().lower()
    word = args.WORD.strip().lower() if args.WORD and not args.no_word else None
    
    action_dir = ACTIONS_DIR / name
    if action_dir.exists():
        print(f"Действие '{name}' уже существует: {action_dir}")
        return
    
    action_dir.mkdir(parents=True)
    
    code = "#!/usr/bin/env python3\n"
    code += f"# Action: {name}\n\n"
    code += "from robohead_controller_actions.main import *\n\n"
    code += f"def run(robohead_controller: RoboheadController, cmds: str):\n"
    code += f"    print(\"Действие {name} выполнено\")\n"
    
    action_file = action_dir / 'action.py'
    with open(action_file, 'w') as f:
        f.write(code)
    print(f"Действие создано: {action_file}")
    
    if word:
        print(f"Добавление слова '{word}' в систему распознавания...")
        class FakeArgs:
            WORD = word
            act_volume = 40
        add_word(FakeArgs())
    
    print(f"\nСледующие шаги:")
    print(f"   1. Отредактируйте {action_file}")
    print(f"   2. Выполните: robohead config words --rebuild")
    print(f"   3. Перезапустите: robohead core restart")

def remove_action(args):
    check_ros()
    name = args.PACKAGE.strip().lower()
    action_dir = ACTIONS_DIR / name
    
    if not action_dir.exists():
        print(f"Действие не найдено: {name}")
        return
    
    if input(f"Удалить '{name}'? (y/n): ").lower() != 'y':
        print("Отменено")
        return
    
    shutil.rmtree(action_dir)
    print(f"Удалено: {action_dir}")

def action_info(args):
    check_ros()
    name = args.PACKAGE.strip().lower()
    action_file = ACTIONS_DIR / name / 'action.py'
    
    if not action_file.exists():
        print(f"Действие не найдено: {name}")
        return
    
    if args.path:
        print(str(action_file.absolute()))
    elif args.data:
        mtime = os.path.getmtime(action_file)
        print(datetime.fromtimestamp(mtime).isoformat())
    elif args.in_file:
        with open(action_file, 'r') as f:
            print(f.read())
    else:
        print(f"Действие: {name}")
        print(f"Путь: {action_file.absolute()}")
        print(f"Обновлено: {datetime.fromtimestamp(os.path.getmtime(action_file)).isoformat()}")
        print(f"Размер: {os.path.getsize(action_file)} байт")

def check_int(value, min_val=0, max_val=100):
    try:
        ivalue = int(value)
        if ivalue < min_val or ivalue > max_val:
            raise argparse.ArgumentTypeError(f"Должно быть от {min_val} до {max_val}")
        return ivalue
    except:
        raise argparse.ArgumentTypeError(f"Неверное значение: {value}")

def main():
    parser = argparse.ArgumentParser(
        prog='robohead',
        description='RoboHead CLI - утилита управления роботом на базе ROS',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog='''
Примеры:
  robohead core restart --debug
  robohead core get_img --pack
  robohead core get_img --device /dev/sdc --output backup.img --2pack
  robohead config speakers set_volume 75 --now
  robohead config words set_activation_word привет --act_volume 35
  robohead action create smile --update-dictionary
  robohead action list

Документация: https://docs.voltbro.ru
        '''
    )
    subparsers = parser.add_subparsers(dest='module', metavar='МОДУЛЬ', help='Доступные модули')

    # CORE
    p_core = subparsers.add_parser('core', help='Управление системой и сервисами')
    core_sub = p_core.add_subparsers(dest='command', metavar='КОМАНДА', help='Команды core')
    
    p_start = core_sub.add_parser('start', help='Запустить сервис robohead_controller')
    p_start.set_defaults(func=core_start)
    
    p_stop = core_sub.add_parser('stop', help='Остановить сервис robohead_controller')
    p_stop.set_defaults(func=core_stop)
    
    p_restart = core_sub.add_parser('restart', help='Перезапустить сервис robohead_controller')
    p_restart.add_argument('--debug', action='store_true', help='Запуск в режиме отладки через roslaunch')
    p_restart.set_defaults(func=core_restart)
    
    p_get_img = core_sub.add_parser('get_img', help='Создать образ SD-карты')
    p_get_img.add_argument('--device', help='Устройство SD-карты (например, /dev/sdc)')
    p_get_img.add_argument('--output', help='Имя выходного файла (без пути)')
    p_get_img.add_argument('--pack', action='store_true', help='Сжать образ через PiShrink')
    p_get_img.add_argument('--2pack', action='store_true', help='Сжать + архивировать в gzip')
    p_get_img.set_defaults(func=core_get_img)
    
    p_shutdown = core_sub.add_parser('shutdown', help='Выключить систему')
    p_shutdown.add_argument('--no-sync', action='store_true', help='Выключение без синхронизации дисков')
    p_shutdown.set_defaults(func=core_shutdown)
    
    p_reboot = core_sub.add_parser('reboot', help='Перезагрузить систему')
    p_reboot.add_argument('--no-sync', action='store_true', help='Перезагрузка без синхронизации дисков')
    p_reboot.set_defaults(func=core_reboot)

    # CONFIG
    p_config = subparsers.add_parser('config', help='Настройки системы')
    config_sub = p_config.add_subparsers(dest='command', metavar='КОМАНДА', help='Команды config')
    
    # Speakers
    p_speakers = config_sub.add_parser('speakers', help='Настройки аудио и динамиков')
    sp_sub = p_speakers.add_subparsers(dest='sp_command', metavar='КОМАНДА', help='Команды для динамиков')
    
    p_vol = sp_sub.add_parser('set_volume', help='Установить уровень громкости')
    p_vol.add_argument('VOLUME', nargs='?', type=lambda x: check_int(x, 0, 100), help='Уровень громкости (0-100)')
    p_vol.add_argument('--default', action='store_true', help='Установить стандартную громкость (50%%)')
    p_vol.add_argument('--now', action='store_true', help='Применить сейчас (текущий сеанс)')
    p_vol.add_argument('--standart', action='store_true', help='Сохранить для автозапуска')
    p_vol.set_defaults(func=set_volume)

    # Voice
    p_voice = config_sub.add_parser('voice', help='Настройки голосового распознавания')
    voice_sub = p_voice.add_subparsers(dest='voice_command', metavar='КОМАНДА', help='Голосовые команды')
    
    p_audio = voice_sub.add_parser('set_audio_to_module', help='Заменить аудиофайл в модуле')
    p_audio.add_argument('--from-file', required=True, help='Путь к исходному аудиофайлу (mp3/wav)')
    p_audio.add_argument('--to-module', required=True, help='Целевой модуль')
    p_audio.add_argument('--to-file', help='Абсолютный путь назначения')
    p_audio.add_argument('--json-pack', help='JSON-файл с маппингом путей')
    p_audio.set_defaults(func=set_audio)

    # Words
    p_words = config_sub.add_parser('words', help='Словарь голосового распознавания')
    p_words.add_argument('--rebuild', action='store_true', help='Пересобрать фонетический словарь')
    p_words.set_defaults(func=lambda a: rebuild_dict(a) if a.rebuild else p_words.print_help())
    
    words_sub = p_words.add_subparsers(dest='words_command', metavar='КОМАНДА', help='Команды для словаря')
    
    p_act = words_sub.add_parser('set_activation_word', help='Добавить активационное слово')
    p_act.add_argument('WORD', help='Слово для добавления')
    p_act.add_argument('--act_volume', type=int, choices=[35, 40, 45], help='Порог активации в дБ')
    p_act.set_defaults(func=add_word)
    
    p_write = words_sub.add_parser('write_from_file', help='Заменить словарь из файла')
    p_write.add_argument('PATH', help='Путь к файлу со списком слов')
    p_write.set_defaults(func=write_dict)

    # ACTION
    p_action = subparsers.add_parser('action', help='Управление действиями')
    action_sub = p_action.add_subparsers(dest='command', metavar='КОМАНДА', help='Команды для действий')
    
    p_list = action_sub.add_parser('list', help='Список доступных действий')
    p_list.set_defaults(func=list_actions)
    
    p_create = action_sub.add_parser('create', help='Создать новое действие')
    p_create.add_argument('NAME', help='Имя действия (папка)')
    p_create.add_argument('WORD', nargs='?', help='Активационное слово (опционально)')
    p_create.add_argument('--set-std', action='store_true', help='Пометить как стандартное')
    p_create.add_argument('--update-dictionary', action='store_true', help='Автодобавление в словарь')
    p_create.add_argument('--no-word', action='store_true', help='Без активационного слова')
    p_create.set_defaults(func=create_action)
    
    p_remove = action_sub.add_parser('remove', help='Удалить действие')
    p_remove.add_argument('PACKAGE', help='Имя действия/пакета')
    p_remove.add_argument('--dont-change-dictionary', action='store_true', help='Не удалять из словаря')
    p_remove.set_defaults(func=remove_action)
    
    p_info = action_sub.add_parser('info', help='Информация о действии')
    p_info.add_argument('PACKAGE', help='Имя действия')
    p_info.add_argument('--path', action='store_true', help='Показать только путь')
    p_info.add_argument('--data', action='store_true', help='Показать только дату')
    p_info.add_argument('--in-file', action='store_true', help='Показать содержимое файла')
    p_info.set_defaults(func=action_info)

    args = parser.parse_args()
    
    if hasattr(args, 'func'):
        try:
            args.func(args)
        except KeyboardInterrupt:
            print("\nПрервано пользователем")
            sys.exit(130)
        except Exception as e:
            print(f"Ошибка: {e}")
            sys.exit(1)
    else:
        parser.print_help()

if __name__ == '__main__':
    main()
